# Optional: wallet the dashboard auto-loads on first paint.
# Lowercase 0x-prefixed, 40 hex chars. Leave unset to start with an empty field.
# Copy this file to .env.local and fill in your own wallet.
NEXT_PUBLIC_DEFAULT_WALLET=

# Optional: default display timezone for the "Local" toggle (IANA name, e.g. Europe/Prague,
# America/New_York). DST is handled automatically. Leave unset to default to UTC; users can
# always switch between UTC and their browser's local timezone in the UI.
NEXT_PUBLIC_DEFAULT_TZ=
